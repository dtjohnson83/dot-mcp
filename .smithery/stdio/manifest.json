            "type": "object",
            "properties": {
              "code": {
                "description": "Violation code (e.g., '395.3A', '395.8')",
                "type": "string"
              },
              "basic_area": {
                "description": "CSA BASIC area (e.g., 'HOS', 'DRF', 'BDD')",
                "type": "string"
              },
              "severity_min": {
                "description": "Minimum severity weight (1-10)",
                "type": "number"
              }
