        {
          "name": "lookup_dot_standard",
          "description": "Search DOT/FMCSA safety standards by topic, keyword, or section number (e.g., 'hours of service', '395.3', 'driver qualification', 'electronic logging device', 'pre-trip inspection'). Returns plain-English summaries with official citations. Covers 49 CFR Parts 350-399 and 100-185.",
          "inputSchema": {
            "type": "object",
            "properties": {
              "query": {
                "type": "string",
                "description": "Search term: topic, keyword, or 49 CFR section number"
              },
              "scope": {
                "default": "all",
                "description": "Filter by regulation scope",
                "type": "string",
                "enum": [
                  "fmcs",
                  "hos",
                  "hazmat",
                  "csa",
                  "driver",
                  "vehicle",
                  "accident",
                  "drug_alcohol",
                  "all"
                ]
              }
            },
            "required": [
              "query"
            ],
            "$schema": "http://json-schema.org/draft-07/schema#"
          },
          "execution": {
            "taskSupport": "forbidden"
          }
        },
        {
          "name": "get_hos_rules",
