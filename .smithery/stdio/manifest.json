          "inputSchema": {
            "type": "object",
            "properties": {
              "carrier_type": {
                "default": "all",
                "description": "Type of carrier operation",
                "type": "string"
              },
              "rule_type": {
                "default": "all",
                "description": "Specific type of HOS rule",
                "type": "string"
              }
            },
            "$schema": "http://json-schema.org/draft-07/schema#"
          },
          "execution": {
            "taskSupport": "forbidden"
          }
        },
